# Токен Telegram-бота
BOT_TOKEN=7123456789:AAF_your_bot_token_here
# Параметры подключения к базе данных
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=random_coffee
POSTGRES_USER=rc_user
POSTGRES_PASSWORD=strong_password_here
# Telegram ID администратора сообщества
ADMIN_TELEGRAM_ID=123456789
# Расписание автоматического раунда матчинга: "DOW HH:MM" (необязательно)
# Поддерживаемые значения DOW: MON TUE WED THU FRI SAT SUN
# Пример: каждый понедельник в 10:00
MATCH_SCHEDULE=MON 10:00
# Сервер видеовстреч для онлайн-пар (необязательно).
# По умолчанию используется публичный Jitsi, допускающий анонимные комнаты.
# Должен оканчиваться на "/". Участники также могут созвониться прямо в Telegram.
VIDEO_CALL_BASE=https://meet.ffmuc.net/
